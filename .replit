modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-atk", "cairo", "cups", "dbus", "expat", "g-ls", "gifsicle", "gitFull", "glib", "imagemagick", "killall", "libdrm", "libgbm", "libwebp", "libxkbcommon", "mesa", "nspr", "nss", "pango", "playwright-driver", "unzip", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb", "yakut"]

[agent]
expertMode = true
integrations = ["hubspot:1.0.0", "google-calendar:1.0.0", "javascript_replit_auth:2.0.0", "javascript_openai_ai_integrations:2.0.0", "javascript_object_storage:2.0.0", "resend:1.0.0", "stripe:2.0.0", "google-sheet:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dev Server"

[[workflows.workflow]]
name = "Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

